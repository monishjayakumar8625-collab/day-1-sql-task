-- inner join 
select * from customers join orderss where customers.order_id = orderss.order_id;
select c1.customer_id ,c1.customer_name as customer_name , o1.order_name
								from customers  c1
                                inner join orderss  o1
                                on c1.order_id = o1.order_id;
                                
-- left outer join 
select c1.customer_id , c1.customer_name , o1.order_name 
				from customers c1
				left join orderss o1
                on c1.order_id = o1.order_id

