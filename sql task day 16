CREATE TABLE employeess(emp_id INT PRIMARY KEY,emp_name VARCHAR(100),salary DECIMAL(10,2),department varchar(10) , phone_no bigint unique );
set sql_safe_updates = 0;


delimiter //

create trigger not_null
before update 
on employeess
for each row 
begin
	if new.phone_no is null then 
	signal sqlstate '45000' 
    set message_text = "phone_no cannot be in null";
    end if ;
end //
delimiter ;

drop trigger not_null;
