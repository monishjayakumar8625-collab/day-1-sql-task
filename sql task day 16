DELIMITER //

CREATE TRIGGER check_department_budget
BEFORE INSERT
ON employees
FOR EACH ROW
BEGIN
    DECLARE dept_budget DECIMAL(10,2);

    SELECT budget
    INTO dept_budget
    FROM departments
    WHERE dept_id = NEW.dept_id;

    IF NEW.salary > dept_budget THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Salary exceeds department budget';
    END IF;
END //

DELIMITER ;

