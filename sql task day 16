create table employees_archive( emp_id int primary key , emp_name varchar(50) , salary decimal(10,2) , archived_at timestamp default current_timestamp);

delimiter //
create trigger after_delete
after delete
on employees
for each row
begin 
	insert into employees_archive(emp_id,emp_name,salary) values (old.emp_id , old.emp_name , old.salary)  ;
end //
delimiter ;

delete from employees where emp_id = 101;
select * from employees;
select * from employees_archive;

